{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Raw View - N02",
      "type": "process",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "-m",
        "visualizers.raw_n02"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true,
        "focus": true
      },
      "problemMatcher": []
    },
    {
      "label": "Raw View - ekidata",
      "type": "process",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "-m",
        "visualizers.raw_ekidata"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true,
        "focus": true
      },
      "problemMatcher": []
    },
    {
      "label": "Build DB",
      "type": "process",
      "command": "/bin/zsh",
      "args": [
        "-c",
        "\"${workspaceFolder}/.venv/bin/python\" -m rail_data.build.main && \"${workspaceFolder}/.venv/bin/python\" -m population_data.build"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true,
        "focus": true
      },
      "problemMatcher": []
    },
    {
      "label": "Rail Network View",
      "type": "process",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "-m",
        "visualizers.network_db",
        "${workspaceFolder}/rail_network.sqlite",
        "--open"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true,
        "focus": true
      },
      "problemMatcher": []
    },
    {
      "label": "Population View",
      "type": "process",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "-m",
        "visualizers.population_mesh",
        "${workspaceFolder}/population_mesh.sqlite",
        "--open"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true,
        "focus": true
      },
      "problemMatcher": []
    }
  ]
}
